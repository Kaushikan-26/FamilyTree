# Server configuration
PORT=5000

# Set to "production" when deploying — makes Express serve the built React app
# (client/dist) from the same server. Leave unset for local development.
# NODE_ENV=production

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/familytree

# Secret used to sign JWT tokens — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret

# How long an issued token stays valid
JWT_EXPIRES_IN=7d

# Origin allowed by CORS (the frontend URL)
CLIENT_URL=http://localhost:5173
